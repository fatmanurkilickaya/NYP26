using System;
using System.Collections.Generic;

class Kisi
{
    private string ad;
    private string soyad;
    private int dogumYili;
    private string tcKimlikNo;

    public string Ad
    {
        get { return ad; }
        set { ad = value; }
    }

    public string Soyad
    {
        get { return soyad; }
        set { soyad = value; }
    }

    public int DogumYili
    {
        get { return dogumYili; }
        set { dogumYili = value; }
    }

    public string TCKimlikNo
    {
        get { return tcKimlikNo; }
        set { tcKimlikNo = value; }
    }

    public List<Arac> Araclar = new List<Arac>();

    public void ArabalarimiListele()
    {
        Console.WriteLine("\nKİŞİ ARABALARIMI LİSTELE");
        Console.WriteLine("------------------------");

        foreach (Arac arac in Araclar)
        {
            Console.WriteLine("Şasi Numarası: " + arac.SasiNo);
            Console.WriteLine("Sahibi: " + Ad + " " + Soyad);
            Console.WriteLine("Edinme Tarihi: " + arac.EdinmeTarihi.ToString("dd.MM.yyyy"));
            Console.WriteLine("Model Yılı: " + arac.Yil);
            Console.WriteLine("Marka: " + arac.Marka);
            Console.WriteLine("Model: " + arac.Model);
            Console.WriteLine("Araç Türü: " + arac.AracTuru);
            Console.WriteLine("Edinme Fiyatı: " + arac.EdinmeFiyati);
            Console.WriteLine("Bu aracın " + arac.KacinciSahibi + ". sahibisiniz.");
            Console.WriteLine("------------------------");
        }
    }
}

class Arac
{
    private string aracTuru;
    private string model;
    private int yil;
    private string marka;
    private DateTime edinmeTarihi;
    private double edinmeFiyati;
    private string sasiNo;
    private int kacinciSahibi;

    public string AracTuru
    {
        get { return aracTuru; }
        set { aracTuru = value; }
    }

    public string Model
    {
        get { return model; }
        set { model = value; }
    }

    public int Yil
    {
        get { return yil; }
        set { yil = value; }
    }

    public string Marka
    {
        get { return marka; }
        set { marka = value; }
    }

    public DateTime EdinmeTarihi
    {
        get { return edinmeTarihi; }
        set { edinmeTarihi = value; }
    }

    public double EdinmeFiyati
    {
        get { return edinmeFiyati; }
        set { edinmeFiyati = value; }
    }

    public string SasiNo
    {
        get { return sasiNo; }
        set { sasiNo = value; }
    }

    public int KacinciSahibi
    {
        get { return kacinciSahibi; }
        set { kacinciSahibi = value; }
    }
}

